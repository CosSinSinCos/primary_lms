{
  "categories": ["唐诗", "宋词", "古文", "现代文"],
  "grades": ["1", "2", "3", "4", "5", "6"],
  "items": [
    {"id": 1, "title": "咏鹅", "author": "骆宾王", "dynasty": "唐", "category": "唐诗", "grade": "1", "lines": ["鹅，鹅，鹅，", "曲项向天歌。", "白毛浮绿水，", "红掌拨清波。"], "note": "白鹅戏水，七岁咏物名篇。"},
    {"id": 2, "title": "江南", "author": "汉乐府", "dynasty": "汉", "category": "古文", "grade": "1", "lines": ["江南可采莲，", "莲叶何田田。", "鱼戏莲叶间。", "鱼戏莲叶东，", "鱼戏莲叶西，", "鱼戏莲叶南，", "鱼戏莲叶北。"], "note": "采莲民歌，重章复沓。"},
    {"id": 3, "title": "画", "author": "王维", "dynasty": "唐", "category": "唐诗", "grade": "1", "lines": ["远看山有色，", "近听水无声。", "春去花还在，", "人来鸟不惊。"], "note": "反衬手法写画中景。"},
    {"id": 4, "title": "悯农（其二）", "author": "李绅", "dynasty": "唐", "category": "唐诗", "grade": "1", "lines": ["锄禾日当午，", "汗滴禾下土。", "谁知盘中餐，", "粒粒皆辛苦。"], "note": "珍惜粮食，体谅农人。"},
    {"id": 5, "title": "古朗月行（节选）", "author": "李白", "dynasty": "唐", "category": "唐诗", "grade": "1", "lines": ["小时不识月，", "呼作白玉盘。", "又疑瑶台镜，", "飞在青云端。"], "note": "以玉盘、瑶台镜喻月。"},
    {"id": 6, "title": "风", "author": "李峤", "dynasty": "唐", "category": "唐诗", "grade": "1", "lines": ["解落三秋叶，", "能开二月花。", "过江千尺浪，", "入竹万竿斜。"], "note": "无形之风，四句写尽。"},
    {"id": 7, "title": "秋天", "author": "", "dynasty": "现代", "category": "现代文", "grade": "1", "lines": ["天气凉了，树叶黄了，", "一片片叶子从树上落下来。", "天空那么蓝，那么高。", "一群大雁往南飞，", "一会儿排成个“人”字，", "一会儿排成个“一”字。", "啊！秋天来了！"], "note": "课文背诵，抓住季节特征。"},
    {"id": 8, "title": "小小的船", "author": "叶圣陶", "dynasty": "现代", "category": "现代文", "grade": "1", "lines": ["弯弯的月儿小小的船，", "小小的船儿两头尖。", "我在小小的船里坐，", "只看见闪闪的星星蓝蓝的天。"], "note": "叠词与比喻，充满童趣。"},
    {"id": 9, "title": "升国旗", "author": "", "dynasty": "现代", "category": "现代文", "grade": "1", "lines": ["五星红旗，我们的国旗。", "国歌声中，徐徐升起；", "迎风飘扬，多么美丽。", "向着国旗，我们立正；", "望着国旗，我们敬礼。"], "note": "礼仪教育，培养爱国情。"},
    {"id": 10, "title": "雪地里的小画家", "author": "程宏明", "dynasty": "现代", "category": "现代文", "grade": "1", "lines": ["下雪啦，下雪啦！", "雪地里来了一群小画家。", "小鸡画竹叶，小狗画梅花，", "小鸭画枫叶，小马画月牙。", "不用颜料不用笔，", "几步就成一幅画。", "青蛙为什么没参加？", "他在洞里睡着啦。"], "note": "动物脚印像画，冬眠常识。"},

    {"id": 11, "title": "春晓", "author": "孟浩然", "dynasty": "唐", "category": "唐诗", "grade": "1", "lines": ["春眠不觉晓，", "处处闻啼鸟。", "夜来风雨声，", "花落知多少。"], "note": "春晨即景，惜春之情。"},
    {"id": 12, "title": "赠汪伦", "author": "李白", "dynasty": "唐", "category": "唐诗", "grade": "1", "lines": ["李白乘舟将欲行，", "忽闻岸上踏歌声。", "桃花潭水深千尺，", "不及汪伦送我情。"], "note": "以水深衬友情之深。"},
    {"id": 13, "title": "静夜思", "author": "李白", "dynasty": "唐", "category": "唐诗", "grade": "1", "lines": ["床前明月光，", "疑是地上霜。", "举头望明月，", "低头思故乡。"], "note": "望月思乡，千古绝唱。"},
    {"id": 14, "title": "寻隐者不遇", "author": "贾岛", "dynasty": "唐", "category": "唐诗", "grade": "1", "lines": ["松下问童子，", "言师采药去。", "只在此山中，", "云深不知处。"], "note": "问答体，隐者高洁。"},
    {"id": 15, "title": "池上", "author": "白居易", "dynasty": "唐", "category": "唐诗", "grade": "1", "lines": ["小娃撑小艇，", "偷采白莲回。", "不解藏踪迹，", "浮萍一道开。"], "note": "童趣盎然，小娃天真。"},
    {"id": 16, "title": "小池", "author": "杨万里", "dynasty": "宋", "category": "宋词", "grade": "1", "lines": ["泉眼无声惜细流，", "树阴照水爱晴柔。", "小荷才露尖尖角，", "早有蜻蜓立上头。"], "note": "初夏小景，生机灵动。"},
    {"id": 17, "title": "人之初", "author": "《三字经》", "dynasty": "宋", "category": "古文", "grade": "1", "lines": ["人之初，性本善。", "性相近，习相远。", "苟不教，性乃迁。", "教之道，贵以专。", "玉不琢，不成器。", "人不学，不知义。"], "note": "蒙学经典，劝学向善。"},
    {"id": 18, "title": "荷叶圆圆", "author": "胡木仁", "dynasty": "现代", "category": "现代文", "grade": "1", "lines": ["荷叶圆圆的，绿绿的。", "小水珠说：“荷叶是我的摇篮。”", "小蜻蜓说：“荷叶是我的停机坪。”", "小青蛙说：“荷叶是我的歌台。”", "小鱼儿说：“荷叶是我的凉伞。”"], "note": "拟人排比，夏日童趣。"},

    {"id": 19, "title": "梅花", "author": "王安石", "dynasty": "宋", "category": "宋词", "grade": "2", "lines": ["墙角数枝梅，", "凌寒独自开。", "遥知不是雪，", "为有暗香来。"], "note": "借梅咏品格之高洁。"},
    {"id": 20, "title": "小儿垂钓", "author": "胡令能", "dynasty": "唐", "category": "唐诗", "grade": "2", "lines": ["蓬头稚子学垂纶，", "侧坐莓苔草映身。", "路人借问遥招手，", "怕得鱼惊不应人。"], "note": "童真专注，怕惊鱼儿。"},
    {"id": 21, "title": "登鹳雀楼", "author": "王之涣", "dynasty": "唐", "category": "唐诗", "grade": "2", "lines": ["白日依山尽，", "黄河入海流。", "欲穷千里目，", "更上一层楼。"], "note": "登高望远，哲理名句。"},
    {"id": 22, "title": "望庐山瀑布", "author": "李白", "dynasty": "唐", "category": "唐诗", "grade": "2", "lines": ["日照香炉生紫烟，", "遥看瀑布挂前川。", "飞流直下三千尺，", "疑是银河落九天。"], "note": "夸张想象，气势磅礴。"},
    {"id": 23, "title": "夜宿山寺", "author": "李白", "dynasty": "唐", "category": "唐诗", "grade": "2", "lines": ["危楼高百尺，", "手可摘星辰。", "不敢高声语，", "恐惊天上人。"], "note": "夸张写楼高，浪漫奇想。"},
    {"id": 24, "title": "敕勒歌", "author": "北朝民歌", "dynasty": "北朝", "category": "古文", "grade": "2", "lines": ["敕勒川，阴山下。", "天似穹庐，笼盖四野。", "天苍苍，野茫茫，", "风吹草低见牛羊。"], "note": "草原牧歌，苍茫辽阔。"},
    {"id": 25, "title": "赋得古原草送别", "author": "白居易", "dynasty": "唐", "category": "唐诗", "grade": "2", "lines": ["离离原上草，", "一岁一枯荣。", "野火烧不尽，", "春风吹又生。", "远芳侵古道，", "晴翠接荒城。", "又送王孙去，", "萋萋满别情。"], "note": "野草生命力，借以送别。"},
    {"id": 26, "title": "植物妈妈有办法", "author": "戴巴棣", "dynasty": "现代", "category": "现代文", "grade": "2", "lines": ["孩子如果已经长大，", "就得告别妈妈，四海为家。", "牛马有脚，鸟有翅膀，", "植物旅行又用什么办法？", "蒲公英妈妈准备了降落伞，", "把它送给自己的娃娃。"], "note": "科普儿歌，拟人生动。"},

    {"id": 27, "title": "村居", "author": "高鼎", "dynasty": "清", "category": "古文", "grade": "2", "lines": ["草长莺飞二月天，", "拂堤杨柳醉春烟。", "儿童散学归来早，", "忙趁东风放纸鸢。"], "note": "春日村景，儿童放鸢。"},
    {"id": 28, "title": "咏柳", "author": "贺知章", "dynasty": "唐", "category": "唐诗", "grade": "2", "lines": ["碧玉妆成一树高，", "万条垂下绿丝绦。", "不知细叶谁裁出，", "二月春风似剪刀。"], "note": "比喻新奇，咏春名篇。"},
    {"id": 29, "title": "晓出净慈寺送林子方", "author": "杨万里", "dynasty": "宋", "category": "宋词", "grade": "2", "lines": ["毕竟西湖六月中，", "风光不与四时同。", "接天莲叶无穷碧，", "映日荷花别样红。"], "note": "西湖夏荷，色彩明丽。"},
    {"id": 30, "title": "绝句", "author": "杜甫", "dynasty": "唐", "category": "唐诗", "grade": "2", "lines": ["两个黄鹂鸣翠柳，", "一行白鹭上青天。", "窗含西岭千秋雪，", "门泊东吴万里船。"], "note": "四句四景，色彩鲜明。"},
    {"id": 31, "title": "悯农（其一）", "author": "李绅", "dynasty": "唐", "category": "唐诗", "grade": "2", "lines": ["春种一粒粟，", "秋收万颗子。", "四海无闲田，", "农夫犹饿死。"], "note": "对比强烈，同情农人。"},
    {"id": 32, "title": "舟夜书所见", "author": "查慎行", "dynasty": "清", "category": "古文", "grade": "2", "lines": ["月黑见渔灯，", "孤光一点萤。", "微微风簇浪，", "散作满河星。"], "note": "河上夜景，由静转动。"},
    {"id": 33, "title": "弟子规（节选）", "author": "李毓秀", "dynasty": "清", "category": "古文", "grade": "2", "lines": ["弟子规，圣人训。", "首孝悌，次谨信。", "泛爱众，而亲仁。", "有余力，则学文。"], "note": "蒙学规范，孝悌谨信。"},

    {"id": 34, "title": "山行", "author": "杜牧", "dynasty": "唐", "category": "唐诗", "grade": "3", "lines": ["远上寒山石径斜，", "白云生处有人家。", "停车坐爱枫林晚，", "霜叶红于二月花。"], "note": "秋山红叶，胜过春花。"},
    {"id": 35, "title": "赠刘景文", "author": "苏轼", "dynasty": "宋", "category": "宋词", "grade": "3", "lines": ["荷尽已无擎雨盖，", "菊残犹有傲霜枝。", "一年好景君须记，", "最是橙黄橘绿时。"], "note": "勉励友人，乐观向上。"},
    {"id": 36, "title": "夜书所见", "author": "叶绍翁", "dynasty": "宋", "category": "宋词", "grade": "3", "lines": ["萧萧梧叶送寒声，", "江上秋风动客情。", "知有儿童挑促织，", "夜深篱落一灯明。"], "note": "秋夜羁旅，以乐衬愁。"},
    {"id": 37, "title": "望天门山", "author": "李白", "dynasty": "唐", "category": "唐诗", "grade": "3", "lines": ["天门中断楚江开，", "碧水东流至此回。", "两岸青山相对出，", "孤帆一片日边来。"], "note": "山水壮阔，气势奔放。"},
    {"id": 38, "title": "饮湖上初晴后雨", "author": "苏轼", "dynasty": "宋", "category": "宋词", "grade": "3", "lines": ["水光潋滟晴方好，", "山色空蒙雨亦奇。", "欲把西湖比西子，", "淡妆浓抹总相宜。"], "note": "晴雨皆宜，西湖如西子。"},
    {"id": 39, "title": "望洞庭", "author": "刘禹锡", "dynasty": "唐", "category": "唐诗", "grade": "3", "lines": ["湖光秋月两相和，", "潭面无风镜未磨。", "遥望洞庭山水翠，", "白银盘里一青螺。"], "note": "湖光山色，比喻精巧。"},
    {"id": 40, "title": "早发白帝城", "author": "李白", "dynasty": "唐", "category": "唐诗", "grade": "3", "lines": ["朝辞白帝彩云间，", "千里江陵一日还。", "两岸猿声啼不住，", "轻舟已过万重山。"], "note": "遇赦放舟，轻快喜悦。"},
    {"id": 41, "title": "采莲曲", "author": "王昌龄", "dynasty": "唐", "category": "唐诗", "grade": "3", "lines": ["荷叶罗裙一色裁，", "芙蓉向脸两边开。", "乱入池中看不见，", "闻歌始觉有人来。"], "note": "人花难辨，采莲如画。"},
    {"id": 42, "title": "司马光", "author": "《宋史》", "dynasty": "宋", "category": "古文", "grade": "3", "lines": ["群儿戏于庭，", "一儿登瓮，足跌没水中。", "众皆弃去，", "光持石击瓮破之，", "水迸，儿得活。"], "note": "破瓮救友，机智沉着。"},

    {"id": 43, "title": "绝句（迟日）", "author": "杜甫", "dynasty": "唐", "category": "唐诗", "grade": "3", "lines": ["迟日江山丽，", "春风花草香。", "泥融飞燕子，", "沙暖睡鸳鸯。"], "note": "春日明丽，动静相宜。"},
    {"id": 44, "title": "惠崇春江晚景", "author": "苏轼", "dynasty": "宋", "category": "宋词", "grade": "3", "lines": ["竹外桃花三两枝，", "春江水暖鸭先知。", "蒌蒿满地芦芽短，", "正是河豚欲上时。"], "note": "题画诗，春江生机。"},
    {"id": 45, "title": "三衢道中", "author": "曾几", "dynasty": "宋", "category": "宋词", "grade": "3", "lines": ["梅子黄时日日晴，", "小溪泛尽却山行。", "绿阴不减来时路，", "添得黄鹂四五声。"], "note": "初夏山行，清新闲适。"},
    {"id": 46, "title": "忆江南", "author": "白居易", "dynasty": "唐", "category": "唐诗", "grade": "3", "lines": ["江南好，风景旧曾谙。", "日出江花红胜火，", "春来江水绿如蓝。", "能不忆江南？"], "note": "词牌名篇，江南忆旧。"},
    {"id": 47, "title": "元日", "author": "王安石", "dynasty": "宋", "category": "宋词", "grade": "3", "lines": ["爆竹声中一岁除，", "春风送暖入屠苏。", "千门万户曈曈日，", "总把新桃换旧符。"], "note": "春节习俗，除旧布新。"},
    {"id": 48, "title": "清明", "author": "杜牧", "dynasty": "唐", "category": "唐诗", "grade": "3", "lines": ["清明时节雨纷纷，", "路上行人欲断魂。", "借问酒家何处有？", "牧童遥指杏花村。"], "note": "清明雨景，旅人愁思。"},
    {"id": 49, "title": "九月九日忆山东兄弟", "author": "王维", "dynasty": "唐", "category": "唐诗", "grade": "3", "lines": ["独在异乡为异客，", "每逢佳节倍思亲。", "遥知兄弟登高处，", "遍插茱萸少一人。"], "note": "重阳思亲，名句千古。"},
    {"id": 50, "title": "滁州西涧", "author": "韦应物", "dynasty": "唐", "category": "唐诗", "grade": "3", "lines": ["独怜幽草涧边生，", "上有黄鹂深树鸣。", "春潮带雨晚来急，", "野渡无人舟自横。"], "note": "涧边幽景，闲淡清远。"},
    {"id": 51, "title": "大林寺桃花", "author": "白居易", "dynasty": "唐", "category": "唐诗", "grade": "3", "lines": ["人间四月芳菲尽，", "山寺桃花始盛开。", "长恨春归无觅处，", "不知转入此中来。"], "note": "山地晚春，意外之喜。"},
    {"id": 52, "title": "守株待兔", "author": "《韩非子》", "dynasty": "战国", "category": "古文", "grade": "3", "lines": ["宋人有耕者。", "田中有株。", "兔走触株，折颈而死。", "因释其耒而守株，冀复得兔。", "兔不可复得，而身为宋国笑。"], "note": "寓言，不可墨守成规。"},

    {"id": 53, "title": "暮江吟", "author": "白居易", "dynasty": "唐", "category": "唐诗", "grade": "4", "lines": ["一道残阳铺水中，", "半江瑟瑟半江红。", "可怜九月初三夜，", "露似真珠月似弓。"], "note": "江边暮景，色彩如画。"},
    {"id": 54, "title": "题西林壁", "author": "苏轼", "dynasty": "宋", "category": "宋词", "grade": "4", "lines": ["横看成岭侧成峰，", "远近高低各不同。", "不识庐山真面目，", "只缘身在此山中。"], "note": "写景说理，当局者迷。"},
    {"id": 55, "title": "雪梅", "author": "卢梅坡", "dynasty": "宋", "category": "宋词", "grade": "4", "lines": ["梅雪争春未肯降，", "骚人阁笔费评章。", "梅须逊雪三分白，", "雪却输梅一段香。"], "note": "梅雪各美，辩证看物。"},
    {"id": 56, "title": "出塞", "author": "王昌龄", "dynasty": "唐", "category": "唐诗", "grade": "4", "lines": ["秦时明月汉时关，", "万里长征人未还。", "但使龙城飞将在，", "不教胡马度阴山。"], "note": "边塞名篇，盼良将保国。"},
    {"id": 57, "title": "凉州词（葡萄美酒）", "author": "王翰", "dynasty": "唐", "category": "唐诗", "grade": "4", "lines": ["葡萄美酒夜光杯，", "欲饮琵琶马上催。", "醉卧沙场君莫笑，", "古来征战几人回？"], "note": "边塞宴饮，豪壮悲凉。"},
    {"id": 58, "title": "夏日绝句", "author": "李清照", "dynasty": "宋", "category": "宋词", "grade": "4", "lines": ["生当作人杰，", "死亦为鬼雄。", "至今思项羽，", "不肯过江东。"], "note": "借古讽今，正气凛然。"},
    {"id": 59, "title": "鹿柴", "author": "王维", "dynasty": "唐", "category": "唐诗", "grade": "4", "lines": ["空山不见人，", "但闻人语响。", "返景入深林，", "复照青苔上。"], "note": "以动衬静，禅意空灵。"},
    {"id": 60, "title": "精卫填海", "author": "《山海经》", "dynasty": "先秦", "category": "古文", "grade": "4", "lines": ["炎帝之少女，名曰女娃。", "女娃游于东海，溺而不返，", "故为精卫，", "常衔西山之木石，以堙于东海。"], "note": "神话，坚韧不屈之志。"},
    {"id": 61, "title": "王戎不取道旁李", "author": "《世说新语》", "dynasty": "南朝", "category": "古文", "grade": "4", "lines": ["王戎七岁，尝与诸小儿游。", "看道边李树多子折枝，", "诸儿竞走取之，唯戎不动。", "人问之，答曰：“树在道边而多子，此必苦李。”", "取之，信然。"], "note": "善观察推理，聪明过人。"},

    {"id": 62, "title": "四时田园杂兴（其二十五）", "author": "范成大", "dynasty": "宋", "category": "宋词", "grade": "4", "lines": ["梅子金黄杏子肥，", "麦花雪白菜花稀。", "日长篱落无人过，", "惟有蜻蜓蛱蝶飞。"], "note": "初夏田园，静中有动。"},
    {"id": 63, "title": "宿新市徐公店", "author": "杨万里", "dynasty": "宋", "category": "宋词", "grade": "4", "lines": ["篱落疏疏一径深，", "树头新绿未成阴。", "儿童急走追黄蝶，", "飞入菜花无处寻。"], "note": "村童追蝶，童趣盎然。"},
    {"id": 64, "title": "清平乐·村居", "author": "辛弃疾", "dynasty": "宋", "category": "宋词", "grade": "4", "lines": ["茅檐低小，溪上青青草。", "醉里吴音相媚好，白发谁家翁媪？", "大儿锄豆溪东，中儿正织鸡笼。", "最喜小儿亡赖，溪头卧剥莲蓬。"], "note": "词牌名篇，农家温情。"},
    {"id": 65, "title": "芙蓉楼送辛渐", "author": "王昌龄", "dynasty": "唐", "category": "唐诗", "grade": "4", "lines": ["寒雨连江夜入吴，", "平明送客楚山孤。", "洛阳亲友如相问，", "一片冰心在玉壶。"], "note": "以冰心玉壶明志清白。"},
    {"id": 66, "title": "塞下曲（月黑）", "author": "卢纶", "dynasty": "唐", "category": "唐诗", "grade": "4", "lines": ["月黑雁飞高，", "单于夜遁逃。", "欲将轻骑逐，", "大雪满弓刀。"], "note": "边塞夜战，英武豪迈。"},
    {"id": 67, "title": "墨梅", "author": "王冕", "dynasty": "元", "category": "古文", "grade": "4", "lines": ["我家洗砚池头树，", "朵朵花开淡墨痕。", "不要人夸好颜色，", "只留清气满乾坤。"], "note": "借梅抒怀，品格高洁。"},
    {"id": 68, "title": "囊萤夜读", "author": "《晋书》", "dynasty": "唐", "category": "古文", "grade": "4", "lines": ["胤恭勤不倦，博学多通。", "家贫不常得油，", "夏月则练囊盛数十萤火以照书，", "以夜继日焉。"], "note": "刻苦求学，囊萤苦读。"},
    {"id": 69, "title": "铁杵成针", "author": "祝穆", "dynasty": "宋", "category": "古文", "grade": "4", "lines": ["磨针溪，在象耳山下。", "世传李太白读书山中，未成，弃去。", "过是溪，逢老媪方磨铁杵。", "问之，曰：“欲作针。”", "太白感其意，还卒业。"], "note": "持之以恒，功到自然成。"},

    {"id": 70, "title": "示儿", "author": "陆游", "dynasty": "宋", "category": "宋词", "grade": "5", "lines": ["死去元知万事空，", "但悲不见九州同。", "王师北定中原日，", "家祭无忘告乃翁。"], "note": "临终绝笔，至死盼统一。"},
    {"id": 71, "title": "题临安邸", "author": "林升", "dynasty": "宋", "category": "宋词", "grade": "5", "lines": ["山外青山楼外楼，", "西湖歌舞几时休？", "暖风熏得游人醉，", "直把杭州作汴州。"], "note": "讽南宋偏安，忧国忧民。"},
    {"id": 72, "title": "己亥杂诗", "author": "龚自珍", "dynasty": "清", "category": "古文", "grade": "5", "lines": ["九州生气恃风雷，", "万马齐喑究可哀。", "我劝天公重抖擞，", "不拘一格降人材。"], "note": "呼唤变革，渴求人才。"},
    {"id": 73, "title": "枫桥夜泊", "author": "张继", "dynasty": "唐", "category": "唐诗", "grade": "5", "lines": ["月落乌啼霜满天，", "江枫渔火对愁眠。", "姑苏城外寒山寺，", "夜半钟声到客船。"], "note": "秋夜羁旅，愁绪悠长。"},
    {"id": 74, "title": "长相思", "author": "纳兰性德", "dynasty": "清", "category": "古文", "grade": "5", "lines": ["山一程，水一程，", "身向榆关那畔行，夜深千帐灯。", "风一更，雪一更，", "聒碎乡心梦不成，故园无此声。"], "note": "词牌名篇，思乡情切。"},
    {"id": 75, "title": "渔歌子", "author": "张志和", "dynasty": "唐", "category": "唐诗", "grade": "5", "lines": ["西塞山前白鹭飞，", "桃花流水鳜鱼肥。", "青箬笠，绿蓑衣，", "斜风细雨不须归。"], "note": "词牌名篇，隐逸闲适。"},
    {"id": 76, "title": "观书有感（二首）", "author": "朱熹", "dynasty": "宋", "category": "宋词", "grade": "5", "lines": ["半亩方塘一鉴开，", "天光云影共徘徊。", "问渠那得清如许？", "为有源头活水来。", "昨夜江边春水生，", "蒙冲巨舰一毛轻。", "向来枉费推移力，", "此日中流自在行。"], "note": "以景喻理，读书养活水。"},
    {"id": 77, "title": "少年中国说（节选）", "author": "梁启超", "dynasty": "清", "category": "古文", "grade": "5", "lines": ["故今日之责任，不在他人，而全在我少年。", "少年智则国智，少年富则国富，", "少年强则国强，少年独立则国独立，", "少年自由则国自由，少年进步则国进步。", "美哉，我少年中国，与天不老！", "壮哉，我中国少年，与国无疆！"], "note": "文言议论文，壮志豪情。"},
    {"id": 78, "title": "古人谈读书", "author": "《论语》等", "dynasty": "先秦", "category": "古文", "grade": "5", "lines": ["知之为知之，不知为不知，是知也。", "敏而好学，不耻下问。", "默而识之，学而不厌，诲人不倦。", "吾尝终日不食，终夜不寝，以思，无益，不如学也。"], "note": "圣贤论学，方法态度。"},

    {"id": 79, "title": "四时田园杂兴（其三十一）", "author": "范成大", "dynasty": "宋", "category": "宋词", "grade": "5", "lines": ["昼出耘田夜绩麻，", "村庄儿女各当家。", "童孙未解供耕织，", "也傍桑阴学种瓜。"], "note": "农家日夜劳作，童趣可爱。"},
    {"id": 80, "title": "稚子弄冰", "author": "杨万里", "dynasty": "宋", "category": "宋词", "grade": "5", "lines": ["稚子金盆脱晓冰，", "彩丝穿取当银钲。", "敲成玉磬穿林响，", "忽作玻璃碎地声。"], "note": "孩童戏冰，声形俱妙。"},
    {"id": 81, "title": "村晚", "author": "雷震", "dynasty": "宋", "category": "宋词", "grade": "5", "lines": ["草满池塘水满陂，", "山衔落日浸寒漪。", "牧童归去横牛背，", "短笛无腔信口吹。"], "note": "村暮牧归，悠然自得。"},
    {"id": 82, "title": "从军行", "author": "王昌龄", "dynasty": "唐", "category": "唐诗", "grade": "5", "lines": ["青海长云暗雪山，", "孤城遥望玉门关。", "黄沙百战穿金甲，", "不破楼兰终不还。"], "note": "边塞誓师，报国壮志。"},
    {"id": 83, "title": "秋夜将晓出篱门迎凉有感", "author": "陆游", "dynasty": "宋", "category": "宋词", "grade": "5", "lines": ["三万里河东入海，", "五千仞岳上摩天。", "遗民泪尽胡尘里，", "南望王师又一年。"], "note": "盼收复失地，悲愤交织。"},
    {"id": 84, "title": "闻官军收河南河北", "author": "杜甫", "dynasty": "唐", "category": "唐诗", "grade": "5", "lines": ["剑外忽传收蓟北，", "初闻涕泪满衣裳。", "却看妻子愁何在，", "漫卷诗书喜欲狂。", "白日放歌须纵酒，", "青春作伴好还乡。", "即从巴峡穿巫峡，", "便下襄阳向洛阳。"], "note": "杜甫“生平第一快诗”。"},
    {"id": 85, "title": "凉州词（黄河远上）", "author": "王之涣", "dynasty": "唐", "category": "唐诗", "grade": "5", "lines": ["黄河远上白云间，", "一片孤城万仞山。", "羌笛何须怨杨柳，", "春风不度玉门关。"], "note": "边塞苍凉，怨而不怒。"},
    {"id": 86, "title": "黄鹤楼送孟浩然之广陵", "author": "李白", "dynasty": "唐", "category": "唐诗", "grade": "5", "lines": ["故人西辞黄鹤楼，", "烟花三月下扬州。", "孤帆远影碧空尽，", "唯见长江天际流。"], "note": "长江送别，情寄流水。"},
    {"id": 87, "title": "泊船瓜洲", "author": "王安石", "dynasty": "宋", "category": "宋词", "grade": "5", "lines": ["京口瓜洲一水间，", "钟山只隔数重山。", "春风又绿江南岸，", "明月何时照我还。"], "note": "“绿”字炼字千古佳话。"},
    {"id": 88, "title": "杨氏之子", "author": "《世说新语》", "dynasty": "南朝", "category": "古文", "grade": "5", "lines": ["梁国杨氏子九岁，甚聪惠。", "孔君平诣其父，父不在，乃呼儿出。", "为设果，果有杨梅。", "孔指以示儿曰：“此是君家果。”", "儿应声答曰：“未闻孔雀是夫子家禽。”"], "note": "妙对机敏，聪慧善辩。"},
    {"id": 89, "title": "自相矛盾", "author": "《韩非子》", "dynasty": "战国", "category": "古文", "grade": "5", "lines": ["楚人有鬻盾与矛者，", "誉之曰：“吾盾之坚，物莫能陷也。”", "又誉其矛曰：“吾矛之利，于物无不陷也。”", "或曰：“以子之矛，陷子之盾，何如？”", "其人弗能应也。"], "note": "寓言，说话不可自相抵触。"},

    {"id": 90, "title": "宿建德江", "author": "孟浩然", "dynasty": "唐", "category": "唐诗", "grade": "6", "lines": ["移舟泊烟渚，", "日暮客愁新。", "野旷天低树，", "江清月近人。"], "note": "羁旅愁思，清寂旷远。"},
    {"id": 91, "title": "六月二十七日望湖楼醉书", "author": "苏轼", "dynasty": "宋", "category": "宋词", "grade": "6", "lines": ["黑云翻墨未遮山，", "白雨跳珠乱入船。", "卷地风来忽吹散，", "望湖楼下水如天。"], "note": "骤雨忽晴，西湖变幻。"},
    {"id": 92, "title": "西江月·夜行黄沙道中", "author": "辛弃疾", "dynasty": "宋", "category": "宋词", "grade": "6", "lines": ["明月别枝惊鹊，清风半夜鸣蝉。", "稻花香里说丰年，听取蛙声一片。", "七八个星天外，两三点雨山前。", "旧时茅店社林边，路转溪桥忽见。"], "note": "词牌名篇，夏夜乡行。"},
    {"id": 93, "title": "过故人庄", "author": "孟浩然", "dynasty": "唐", "category": "唐诗", "grade": "6", "lines": ["故人具鸡黍，", "邀我至田家。", "绿树村边合，", "青山郭外斜。", "开轩面场圃，", "把酒话桑麻。", "待到重阳日，", "还来就菊花。"], "note": "田园友情，淳朴真挚。"},
    {"id": 94, "title": "春日", "author": "朱熹", "dynasty": "宋", "category": "宋词", "grade": "6", "lines": ["胜日寻芳泗水滨，", "无边光景一时新。", "等闲识得东风面，", "万紫千红总是春。"], "note": "寻春悟理，生机盎然。"},
    {"id": 95, "title": "回乡偶书", "author": "贺知章", "dynasty": "唐", "category": "唐诗", "grade": "6", "lines": ["少小离家老大回，", "乡音无改鬓毛衰。", "儿童相见不相识，", "笑问客从何处来。"], "note": "久客归乡，物是人非。"},
    {"id": 96, "title": "伯牙鼓琴", "author": "《吕氏春秋》", "dynasty": "先秦", "category": "古文", "grade": "6", "lines": ["伯牙鼓琴，锺子期听之。", "方鼓琴而志在太山，锺子期曰：“善哉乎鼓琴，巍巍乎若太山。”", "少选之间而志在流水，锺子期又曰：“善哉乎鼓琴，汤汤乎若流水。”", "锺子期死，伯牙破琴绝弦，终身不复鼓琴，以为世无足复为鼓琴者。"], "note": "知音难觅，高山流水。"},
    {"id": 97, "title": "书戴嵩画牛", "author": "苏轼", "dynasty": "宋", "category": "古文", "grade": "6", "lines": ["蜀中有杜处士，好书画，所宝以百数。", "有戴嵩《牛》一轴，尤所爱，锦囊玉轴，常以自随。", "一日曝书画，有一牧童见之，拊掌大笑，", "曰：“此画斗牛也。牛斗，力在角，尾搐入两股间，今乃掉尾而斗，谬矣。”", "处士笑而然之。"], "note": "观察入微，实践出真知。"},
    {"id": 98, "title": "匆匆", "author": "朱自清", "dynasty": "现代", "category": "现代文", "grade": "6", "lines": ["燕子去了，有再来的时候；", "杨柳枯了，有再青的时候；", "桃花谢了，有再开的时候。", "但是，聪明的，你告诉我，", "我们的日子为什么一去不复返呢？", "——是有人偷了他们罢：那是谁？", "又藏在何处呢？是他们自己逃走了罢：", "如今又到了哪里呢？"], "note": "散文名篇，惜时如金。"},
    {"id": 99, "title": "少年闰土（节选）", "author": "鲁迅", "dynasty": "现代", "category": "现代文", "grade": "6", "lines": ["深蓝的天空中挂着一轮金黄的圆月，", "下面是海边的沙地，", "都种着一望无际的碧绿的西瓜，", "其间有一个十一二岁的少年，", "项带银圈，手捏一柄钢叉，", "向一匹猹尽力的刺去……"], "note": "小说名段，海边少年英姿。"},

    {"id": 100, "title": "寒食", "author": "韩翃", "dynasty": "唐", "category": "唐诗", "grade": "6", "lines": ["春城无处不飞花，", "寒食东风御柳斜。", "日暮汉宫传蜡烛，", "轻烟散入五侯家。"], "note": "寒食节俗，暗含讽喻。"},
    {"id": 101, "title": "迢迢牵牛星", "author": "《古诗十九首》", "dynasty": "汉", "category": "古文", "grade": "6", "lines": ["迢迢牵牛星，皎皎河汉女。", "纤纤擢素手，札札弄机杼。", "终日不成章，泣涕零如雨。", "河汉清且浅，相去复几许。", "盈盈一水间，脉脉不得语。"], "note": "牛郎织女，相思哀婉。"},
    {"id": 102, "title": "十五夜望月", "author": "王建", "dynasty": "唐", "category": "唐诗", "grade": "6", "lines": ["中庭地白树栖鸦，", "冷露无声湿桂花。", "今夜月明人尽望，", "不知秋思落谁家。"], "note": "中秋望月，秋思绵绵。"},
    {"id": 103, "title": "马诗", "author": "李贺", "dynasty": "唐", "category": "唐诗", "grade": "6", "lines": ["大漠沙如雪，", "燕山月似钩。", "何当金络脑，", "快走踏清秋。"], "note": "咏马言志，渴望建功。"},
    {"id": 104, "title": "石灰吟", "author": "于谦", "dynasty": "明", "category": "古文", "grade": "6", "lines": ["千锤万凿出深山，", "烈火焚烧若等闲。", "粉骨碎身浑不怕，", "要留清白在人间。"], "note": "托物言志，清白品格。"},
    {"id": 105, "title": "竹石", "author": "郑燮", "dynasty": "清", "category": "古文", "grade": "6", "lines": ["咬定青山不放松，", "立根原在破岩中。", "千磨万击还坚劲，", "任尔东西南北风。"], "note": "咏竹明志，坚韧不屈。"},
    {"id": 106, "title": "采薇（节选）", "author": "《诗经》", "dynasty": "先秦", "category": "古文", "grade": "6", "lines": ["昔我往矣，杨柳依依。", "今我来思，雨雪霏霏。", "行道迟迟，载渴载饥。", "我心伤悲，莫知我哀！"], "note": "诗经名篇，征人归思。"},
    {"id": 107, "title": "学弈", "author": "《孟子》", "dynasty": "先秦", "category": "古文", "grade": "6", "lines": ["弈秋，通国之善弈者也。", "使弈秋诲二人弈，其一人专心致志，惟弈秋之为听；", "一人虽听之，一心以为有鸿鹄将至，思援弓缴而射之。", "虽与之俱学，弗若之矣。", "为是其智弗若与？曰：非然也。"], "note": "专心致志，方能学成。"},
    {"id": 108, "title": "两小儿辩日", "author": "《列子》", "dynasty": "先秦", "category": "古文", "grade": "6", "lines": ["孔子东游，见两小儿辩斗，问其故。", "一儿曰：“我以日始出时去人近，而日中时远也。”", "一儿曰：“日初出大如车盖，及日中则如盘盂，此不为远者小而近者大乎？”", "一儿曰：“日初出沧沧凉凉，及其日中如探汤，此不为近者热而远者凉乎？”", "孔子不能决也。两小儿笑曰：“孰为汝多知乎？”"], "note": "独立思考，学无止境。"},
    {"id": 109, "title": "为人民服务（节选）", "author": "毛泽东", "dynasty": "现代", "category": "现代文", "grade": "6", "lines": ["我们的共产党和共产党所领导的八路军、新四军，是革命的队伍。", "我们这个队伍完全是为着解放人民的，是彻底地为人民的利益工作的。", "张思德同志就是我们这个队伍中的一个同志。", "人总是要死的，但死的意义有不同。", "为人民利益而死，就比泰山还重。"], "note": "议论文名篇，宗旨鲜明。"},
    {"id": 110, "title": "那个星期天", "author": "史铁生", "dynasty": "现代", "category": "现代文", "grade": "6", "lines": ["我还记得我的第一次盼望——", "那是个星期天，从早晨到下午，一直到天色昏暗下去。", "母亲答应带我出去，", "我藏在大门后，等她洗完衣服、买完菜、翻箱倒柜……", "光线漫长而急遽地变化，等待里的期盼与失落。"], "note": "散文名段，等待中的心理。"}
  ]
}
